{
  "name": "paceaux3",
  "version": "1.0.0",
  "description": "Paceaux3 theme",
  "browserslist": [
    "> 5%"
  ],
  "scripts": {
    "clean": "rm -rf public/*",
    "styles:lint": "stylelint src/styles/**/*.css",
    "styles:lint:fix": "stylelint src/styles/**/*.css --fix",
    "styles:build": "postcss src/styles/main.css -o style.css"
  },
  "devDependencies": {
    "copyfiles": "^2.4.1",
    "cssnano": "^7.0.4",
    "postcss": "^8.4.39",
    "postcss-cli": "^11.0.0",
    "postcss-cssnext": "^3.1.1",
    "postcss-import": "^16.1.0",
    "postcss-preset-env": "^11.2.0",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^7.0.1"
  },
  "dependencies": {
    "@stylistic/stylelint-plugin": "^5.0.1"
  }
}
